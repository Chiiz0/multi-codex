FROM node:25.9.0-bookworm AS build

ARG PNPM_VERSION=11.7.0
WORKDIR /src/apps/web
RUN npm install -g "pnpm@${PNPM_VERSION}"
COPY apps/web/package.json apps/web/tsconfig.json apps/web/tsconfig.node.json apps/web/vite.config.ts ./
COPY apps/web/index.html ./index.html
COPY apps/web/src ./src
RUN pnpm install && pnpm build

FROM nginx:1.29-alpine
COPY deployments/docker/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /src/apps/web/dist /usr/share/nginx/html
EXPOSE 80
